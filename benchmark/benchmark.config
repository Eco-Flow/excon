// Nextflow config applied to all benchmark runs.
// Uses timestamped filenames for trace/report/timeline so that each run
// (including resumes) gets its own file — matching Nextflow's default behaviour
// for pipeline_dag. collect_metrics.py picks up the latest trace per run.

def ts = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

trace {
    file      = "output/pipeline_info/execution_trace_${ts}.tsv"
    overwrite = true
}
report {
    file      = "output/pipeline_info/execution_report_${ts}.html"
    overwrite = true
}
timeline {
    file      = "output/pipeline_info/execution_timeline_${ts}.html"
    overwrite = true
}
